generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  binaryTargets = ["native", "linux-musl", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model User { 
  id    Int     @id @default(autoincrement()) 
  email String  @unique
  name  String @unique
  posts Post[]
}

model User2 { 
  id    Int     @id @default(autoincrement()) 
  email String  @unique
  name  String @unique
} 

model Post { 
  id        Int     @id @default(autoincrement()) 
  title     String
  content   String? 
  author    User    @relation(fields: [authorId], references: [id]) 
  authorId  Int
} 